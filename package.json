{
	"name": "kharcha-backend",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun run --hot src/index.ts",
		"build": "bun build src/index.ts --outdir dist",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"quality": "bun run lint && bun run typecheck",
		"db:migrate": "bun run src/db/migrate.ts",
		"db:push": "drizzle-kit push",
		"db:seed": "bun run src/db/seed.ts",
		"db:studio": "DATABASE_URL=postgres://postgres:postgres@localhost:5432/kharcha drizzle-kit studio"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.10",
		"postgres": "^3.4.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"bun-types": "^1.3.11",
		"drizzle-kit": "^0.31.10",
		"lefthook": "^2.1.4",
		"typescript": "^6.0.2"
	},
	"engines": {
		"bun": ">=1.2.0"
	}
}
