# Required
DATABASE_URL=postgres://postgres:postgres@postgres:5432/kharcha
POSTMARK_WEBHOOK_TOKEN=your_postmark_webhook_token

# Optional
GMAIL_SYNC_ENABLED_FOR=User1,User2
EMAIL_DOMAIN=mail.thechetanjain.com
GEMINI_API_KEY=your_gemini_api_key
PORT=3000

# Note: DATABASE_URL uses "postgres" as hostname (Docker service name).
# For host machine access (e.g. db:studio), use "localhost" instead.
